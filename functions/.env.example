# Firebase Project Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Device Settings
COMMAND_TIMEOUT_MS=30000
COMMAND_RETRY_MAX_ATTEMPTS=3
COMMAND_RETRY_BACKOFF_MS=2000
DEVICE_OFFLINE_THRESHOLD_MS=120000

# Rate Limiting
RATE_LIMIT_PER_USER_PER_HOUR=1000
RATE_LIMIT_MANUAL_FEED_PER_HOUR=48
RATE_LIMIT_SCHEDULE_OPS_PER_HOUR=100

# Monitoring & Alerts
ENABLE_DETAILED_LOGGING=true
ALERT_ON_DEVICE_OFFLINE=true
MAX_HISTORY_ENTRIES=10000
HISTORY_RETENTION_DAYS=90

# Feature Flags
ENABLE_COMMAND_DEDUPLICATION=true
ENABLE_WEIGHT_TELEMETRY=false
